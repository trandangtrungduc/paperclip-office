{
  "name": "paperclip-office",
  "version": "1.0.0",
  "description": "2D pixel-art office visualization for Paperclip AI companies",
  "main": "./out/main/index.js",
  "author": "paperclip-office",
  "license": "MIT",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "start": "electron-vite preview",
    "typecheck": "tsc --noEmit",
    "typecheck:main": "tsc --noEmit -p tsconfig.main.json",
    "typecheck:preload": "tsc --noEmit -p tsconfig.preload.json",
    "typecheck:renderer": "tsc --noEmit -p tsconfig.renderer.json",
    "lint": "eslint src/",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "package": "electron-vite build && electron-builder --win --config.win.icon=resources/ico.ico --publish never",
    "package:win": "electron-vite build && electron-builder --win --config.win.icon=resources/ico.ico --publish never",
    "package:linux": "electron-vite build && electron-builder --linux --publish never"
  },
  "dependencies": {
    "@electron-toolkit/utils": "^3.0.0",
    "@pixi/react": "^8.0.5",
    "date-fns": "^4.1.0",
    "electron-store": "^10.0.0",
    "ky": "^1.7.0",
    "pixi.js": "^8.17.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "ws": "^8.18.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@playwright/test": "^1.50.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/ws": "^8.5.0",
    "@vitejs/plugin-react": "^5.1.4",
    "@vitest/coverage-v8": "^3.2.4",
    "electron": "^41.2.0",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "eslint": "^9.0.0",
    "png-to-ico": "^3.0.1",
    "prettier": "^3.4.0",
    "sharp": "^0.34.5",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
